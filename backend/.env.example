# Application
NODE_ENV=development
PORT=3001

# Database (PostgreSQL)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/hotel_management_dev

# Redis
REDIS_URL=redis://localhost:6379

# JWT — must be at least 32 characters
JWT_SECRET=change-me-to-a-secure-random-string-min-32-chars
JWT_REFRESH_SECRET=change-me-to-another-secure-random-string-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Payments (Phase 7)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# TRANZILA_TERMINAL=
# TRANZILA_PASSWORD=

# Email (Phase 1)
# SENDGRID_API_KEY=
# EMAIL_FROM=noreply@hotel.com

# CSRF protection (separate from JWT)
CSRF_SECRET=change-me-to-a-secure-random-string-min-32-chars

# Refresh token HMAC (separate key for hashing refresh tokens)
REFRESH_TOKEN_HMAC_KEY=change-me-to-a-secure-random-string-min-32-chars

# Redis password (empty = no auth, set for all non-dev environments)
REDIS_PASSWORD=
